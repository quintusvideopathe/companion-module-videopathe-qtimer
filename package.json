{
  "name": "companion-module-videopathe-qtimer",
  "version": "1.0.0",
  "description": "Bitfocus Companion module for QTimer",
  "main": "dist/main.js",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/videopathe/companion-module-videopathe-qtimer.git"
  },
  "bugs": {
    "url": "https://github.com/videopathe/companion-module-videopathe-qtimer/issues"
  },
  "engines": {
    "node": "^22.20",
    "yarn": "^4"
  },
  "scripts": {
    "postinstall": "husky",
    "format": "prettier -w .",
    "build": "rimraf dist && yarn build:main",
    "build:main": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint:raw": "eslint",
    "lint": "yarn lint:raw .",
    "package": "yarn build && companion-module-build"
  },
  "dependencies": {
    "@companion-module/base": "~1.14.1",
    "@types/ws": "^8.18.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@companion-module/tools": "^2.6.1",
    "@types/node": "^22.19.3",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.51.0"
  },
  "prettier": "@companion-module/tools/.prettierrc.json",
  "lint-staged": {
    "*.{css,json,md,scss}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "yarn lint:raw --fix"
    ]
  },
  "packageManager": "yarn@4.12.0"
}
